<Window x:Class="WpfCommander.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfCommander.ViewModels"
        mc:Ignorable="d"
        Title="WPF Commander" Height="600" Width="1000"
        WindowStartupLocation="CenterScreen">

	<Window.Resources>
		<local:InverseBooleanToVisibilityConverter x:Key="InverseBoolToVisibilityConverter"/>
	</Window.Resources>

	<Grid>
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="*"/>
			<RowDefinition Height="Auto"/>
		</Grid.RowDefinitions>

		
		<StackPanel Grid.Row="0" Orientation="Horizontal" Margin="5" Background="LightGray">
			<Button Content="F5 - Копировать" Width="120" Height="30" Margin="5"
                    Command="{Binding CopyCommand}"/>
			<Button Content="F6 - Переместить" Width="120" Height="30" Margin="5"
                    Command="{Binding MoveCommand}"/>
			<Button Content="F7 - Новая папка" Width="120" Height="30" Margin="5"
                    Command="{Binding CreateFolderCommand}"/>
			<Button Content="F8 - Удалить" Width="120" Height="30" Margin="5"
                    Command="{Binding DeleteCommand}"/>
		</StackPanel>

		<!-- Две панели -->
		<Grid Grid.Row="1">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="*"/>
				<ColumnDefinition Width="5"/>
				<ColumnDefinition Width="*"/>
			</Grid.ColumnDefinitions>

			<!-- ЛЕВАЯ ПАНЕЛЬ -->
			<Border Grid.Column="0" BorderBrush="{Binding LeftPanel.ActiveBorderBrush}"
                    BorderThickness="2" Margin="5">
				<Grid>
					<Grid.RowDefinitions>
						<RowDefinition Height="Auto"/>
						<RowDefinition Height="Auto"/>
						<RowDefinition Height="*"/>
					</Grid.RowDefinitions>

					<ComboBox Grid.Row="0" ItemsSource="{Binding Drives}"
                              SelectedItem="{Binding LeftPanel.CurrentPath}"
                              Margin="5" Height="25"/>

					<TextBox Grid.Row="1" Text="{Binding LeftPanel.CurrentPath, UpdateSourceTrigger=PropertyChanged}"
                             Margin="5" Height="25" IsReadOnly="True" Background="LightYellow"/>

					<ListView Grid.Row="2" Margin="5"
                              ItemsSource="{Binding LeftPanel.Items}"
                              SelectedItem="{Binding LeftPanel.SelectedItem}"
                              SelectionMode="Extended"
                              MouseDoubleClick="LeftPanel_MouseDoubleClick"
                              GotFocus="LeftPanel_GotFocus"
                              SelectionChanged="LeftPanel_SelectionChanged">
						<ListView.View>
							<GridView>
								<GridViewColumn Header="Имя" Width="250" DisplayMemberBinding="{Binding Name}"/>
								<GridViewColumn Header="Тип" Width="100" DisplayMemberBinding="{Binding Type}"/>
								<GridViewColumn Header="Размер" Width="100" DisplayMemberBinding="{Binding Size}"/>
								<GridViewColumn Header="Дата изменения" Width="150"
                                                DisplayMemberBinding="{Binding ModifiedDate, StringFormat=\{0:yyyy.MM.dd HH:mm\}}"/>
							</GridView>
						</ListView.View>
					</ListView>
				</Grid>
			</Border>

			<!-- РАЗДЕЛИТЕЛЬ -->
			<GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" Background="DarkGray" Width="5"/>

			<!-- ПРАВАЯ ПАНЕЛЬ -->
			<Border Grid.Column="2" BorderBrush="{Binding RightPanel.ActiveBorderBrush}"
                    BorderThickness="2" Margin="5">
				<Grid>
					<Grid.RowDefinitions>
						<RowDefinition Height="Auto"/>
						<RowDefinition Height="Auto"/>
						<RowDefinition Height="*"/>
					</Grid.RowDefinitions>

					<ComboBox Grid.Row="0" ItemsSource="{Binding Drives}"
                              SelectedItem="{Binding RightPanel.CurrentPath}"
                              Margin="5" Height="25"/>

					<TextBox Grid.Row="1" Text="{Binding RightPanel.CurrentPath, UpdateSourceTrigger=PropertyChanged}"
                             Margin="5" Height="25" IsReadOnly="True" Background="LightYellow"/>

					<ListView Grid.Row="2" Margin="5"
                              ItemsSource="{Binding RightPanel.Items}"
                              SelectedItem="{Binding RightPanel.SelectedItem}"
                              SelectionMode="Extended"
                              MouseDoubleClick="RightPanel_MouseDoubleClick"
                              GotFocus="RightPanel_GotFocus"
                              SelectionChanged="RightPanel_SelectionChanged">
						<ListView.View>
							<GridView>
								<GridViewColumn Header="Имя" Width="250" DisplayMemberBinding="{Binding Name}"/>
								<GridViewColumn Header="Тип" Width="100" DisplayMemberBinding="{Binding Type}"/>
								<GridViewColumn Header="Размер" Width="100" DisplayMemberBinding="{Binding Size}"/>
								<GridViewColumn Header="Дата изменения" Width="150"
                                                DisplayMemberBinding="{Binding ModifiedDate, StringFormat=\{0:yyyy.MM.dd HH:mm\}}"/>
							</GridView>
						</ListView.View>
					</ListView>
				</Grid>
			</Border>
		</Grid>

		<StatusBar Grid.Row="2">
			<StatusBarItem>
				<TextBlock Text="F5-Копировать | F6-Переместить | F7-Создать папку | F8-Удалить"/>
			</StatusBarItem>
		</StatusBar>
	</Grid>
</Window>
